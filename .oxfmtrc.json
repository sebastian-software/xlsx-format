{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 4,
	"semi": true,
	"singleQuote": false,
	"trailingComma": "all",
	"printWidth": 120,
	"endOfLine": "lf",
	"sortPackageJson": false,
	"ignorePatterns": ["dist/", "node_modules/", "package-lock.json", "docs/build/", "docs/.react-router/"]
}
